# ------------------------------------------------------------------
# Conexion a PostgreSQL
# En Railway: copia la variable DATABASE_URL del servicio Postgres.
# En local con Docker: postgresql://postgres:postgres@localhost:5432/unidos
# ------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unidos?schema=public"

# Clave para acceder al panel de administracion (cambiala por una segura)
ADMIN_TOKEN="cambia-esta-clave-secreta"

# Numero de WhatsApp para reportes (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP="584129317277"

# URL publica del sitio (para la PWA y metadatos)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
